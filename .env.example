# =============================================================================
# Question Engine — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values you need.
# Only OPENAI_API_KEY or ANTHROPIC_API_KEY is required to get started;
# everything else is optional and enables additional features.

# -----------------------------------------------------------------------------
# Core LLM API Keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# KiloCode proxy (sets OPENAI_API_KEY/BASE automatically when present)
KILOCODE_API_KEY=
KILOCODE_API_BASE=https://kilo.ai/api/openrouter

# -----------------------------------------------------------------------------
# Additional LLM Provider Keys
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
COHERE_API_KEY=
MISTRAL_API_KEY=
GOOGLE_API_KEY=
HYPERBOLIC_API_KEY=
SAMBANOVA_API_KEY=
SCALEWAY_API_KEY=
CLOUDFLARE_API_KEY=

# -----------------------------------------------------------------------------
# Telegram Channel
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=

# -----------------------------------------------------------------------------
# Slack Channel
# -----------------------------------------------------------------------------
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_DEFAULT_CHANNEL=

# -----------------------------------------------------------------------------
# Email Channel
# -----------------------------------------------------------------------------
EMAIL_IMAP_HOST=
EMAIL_SMTP_HOST=
EMAIL_USERNAME=
EMAIL_PASSWORD=

# -----------------------------------------------------------------------------
# Webhook Channel
# -----------------------------------------------------------------------------
WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Runtime / Misc
# -----------------------------------------------------------------------------
# Comma-separated list of allowed CORS origins (defaults to localhost:8000)
QE_CORS_ORIGINS=

# Root path for full-access agent workspace (defaults to /)
QE_FULL_ACCESS_ROOT=

# Set to any non-empty value to prefer local models in the router
PREFER_LOCAL=
